{
  "description": "Auto-update hook for adeel plugin",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/bin/adeel-update-check\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
