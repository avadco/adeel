#!/usr/bin/env bash
# adeel-config — read/write $HOME/.adeel/config.yaml
#
# Usage:
#   adeel-config get <key>          — read a config value
#   adeel-config set <key> <value>  — write a config value
#   adeel-config list               — show all config
#
set -euo pipefail

STATE_DIR="$HOME/.adeel"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: adeel-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: adeel-config set <key> <value>}"
    VALUE="${3:?Usage: adeel-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      # Portable in-place edit (BSD sed uses -i '', GNU sed uses -i without arg)
      _tmpfile="$(mktemp "${CONFIG_FILE}.XXXXXX")"
      sed "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE" > "$_tmpfile" && mv "$_tmpfile" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: adeel-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
