#!/usr/bin/env bash
# adeel-review-read — read review log and config for dashboard
# Usage: adeel-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/adeel-slug" 2>/dev/null)"
ADEEL_HOME="${ADEEL_HOME:-$HOME/.adeel}"
cat "$ADEEL_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/adeel-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
